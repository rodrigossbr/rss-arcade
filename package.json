{
  "name": "rss-arcade",
  "version": "0.0.1",
  "author": "Rodrigo S. Santos <rodrigoss.br@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/rodrigossbr/rss-arcade#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigossbr/rss-arcade.git"
  },
  "bugs": {
    "url": "https://github.com/rodrigossbr/rss-arcade/issues"
  },
  "description": "Uma coletânea de jogos clássicos (Snake, River Raid) desenvolvidos com Angular, focada em sistemas de temas dinâmicos e design retrô.",
  "keywords": [
    "angular-games",
    "retro-gaming",
    "atari-2600-style",
    "snake-game",
    "river-raid-clone",
    "css-theming",
    "monorepo",
    "nx",
    "web-arcade",
    "frontend-portfolio",
    "component-architecture"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@rssbr/state-store": "^0.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
